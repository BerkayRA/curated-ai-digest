# =============================================================================
# Curated AI Digest — runtime environment variables
# Copy to .env and fill in real values before running `docker compose up`.
# This file is safe to commit; .env is gitignored.
# =============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
# Inside Docker Compose the hostname is `db` (the service name), port 5432.
# On the host machine (for local dev / migrations) use localhost:5433 instead.
DATABASE_URL=postgresql://digest:digest@db:5432/curated_ai_digest

# ─── AI / search ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
EXA_API_KEY=exa-...

# ─── Auth (NextAuth v5 / next-auth beta) ─────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=change-me-generate-a-real-secret

# AUTH_MODE selects the sign-in flow:
#   entra (default) — Microsoft Entra ID SSO (uses the AUTH_MICROSOFT_* vars below)
#   local           — single-admin email + argon2 password, no SSO (handy for local dev)
AUTH_MODE=entra

# Microsoft Entra ID (Azure AD) OAuth app for SSO (AUTH_MODE=entra)
AUTH_MICROSOFT_ENTRA_ID_ID=00000000-0000-0000-0000-000000000000
AUTH_MICROSOFT_ENTRA_ID_SECRET=your-entra-client-secret
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=your-tenant-id

# Local-mode admin credentials (AUTH_MODE=local). Generate the hash with:
#   node -e "require('argon2').hash(process.argv[1],{type:2}).then(console.log)" 'YourPassword'
# IMPORTANT: an argon2 hash contains '$' (e.g. $argon2id$v=19$m=...). The env loader
# (dotenv-expand) treats '$name' as variable interpolation and will silently CORRUPT
# the hash. Escape every '$' as '\$' in this file, or the login will reject the password.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD_HASH=\$argon2id\$v=19\$m=65536,t=3,p=4\$...escaped...

# ─── Email delivery (Azure Communication Services — default provider) ─────────
ACS_CONNECTION_STRING=endpoint=https://your-acs.communication.azure.com/;accesskey=...
ACS_SENDER_ADDRESS=DoNotReply@your-acs-verified-domain.com

# Microsoft Graph (alternate provider)
# GRAPH_TENANT_ID=
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=
# GRAPH_SENDER_ADDRESS=

# Resend (alternate provider)
# RESEND_API_KEY=re_...
# RESEND_SENDER_ADDRESS=noreply@yourdomain.com

# ─── Application ─────────────────────────────────────────────────────────────
# Public URL used for email links, approval URLs, etc.
APP_BASE_URL=http://localhost:3100

# ─── Auto-send guardrails ─────────────────────────────────────────────────────
# Set to "true" to allow the worker to send without human approval.
# The auto-send kill-switch in Settings overrides this at runtime.
AUTOSEND_ENABLED=false
# Maximum subscriber count allowed for an unattended auto-send.
AUTOSEND_MAX_SUBSCRIBERS=500
