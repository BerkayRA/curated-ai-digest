# ---------------------------------------------------------------------------
# Curated AI Digest Worker — environment variables
# Copy to .env and fill in values before running.
# ---------------------------------------------------------------------------

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/curated_ai_digest

# Required: Anthropic API key (used by the curation pipeline)
ANTHROPIC_API_KEY=sk-ant-...

# Required: Exa API key (used by ingest stage)
EXA_API_KEY=...

# Required: Base URL of the web app (used to build unsubscribe links)
APP_BASE_URL=https://digest.example.com

# ---------------------------------------------------------------------------
# Email provider — set the vars for whichever provider is active in Settings
# ---------------------------------------------------------------------------

# Azure Communication Services (default provider)
ACS_CONNECTION_STRING=endpoint=https://...;accesskey=...
ACS_SENDER_ADDRESS=digest@<acs-domain>.azurecomm.net

# Microsoft Graph (alternative)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_UPN=digest@example.com

# Resend (alternative)
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=digest@example.com

# ---------------------------------------------------------------------------
# Auto-send guardrails (all optional — defaults shown)
# ---------------------------------------------------------------------------

# Minimum number of active subscribers required for auto-send (default: 1)
AUTOSEND_MIN_SUBSCRIBERS=1

# Maximum number of active subscribers allowed for auto-send without human approval (default: 50000)
AUTOSEND_MAX_SUBSCRIBERS=50000

# Emergency kill-switch: set to "true" to disable all auto-sends immediately
AUTOSEND_KILL_SWITCH=false

# ---------------------------------------------------------------------------
# test-send script (pnpm --filter @digest/worker test-send) — optional.
# Put these in a gitignored apps/worker/.env.local so the API key never lands in
# your shell history. Inline env vars on the command line still override these.
# ---------------------------------------------------------------------------

# RESEND_API_KEY=re_...
# Sender — in Resend TEST mode (no verified domain) this MUST be onboarding@resend.dev.
# TEST_FROM=Curated AI Digest <onboarding@resend.dev>
# Recipient — in TEST mode this MUST be the email you registered with Resend.
# TEST_TO=you@example.com
# TEST_SPONSORED=1   # optional: render the Phase 6 "Sponsorlu" slot
