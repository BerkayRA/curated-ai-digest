{
  "name": "@digest/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "lint": "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "curate:manual": "tsx src/manual-curate.ts",
    "test-send": "tsx src/test-send.ts"
  },
  "dependencies": {
    "@digest/db": "workspace:*",
    "@digest/shared": "workspace:*",
    "@digest/curation": "workspace:*",
    "@digest/email": "workspace:*",
    "@digest/delivery": "workspace:*",
    "croner": "^9.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
