# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://digest:digest@localhost:5433/curated_ai_digest"

# ── Application ───────────────────────────────────────────────────────────────
APP_BASE_URL="http://localhost:3100"

# ── Authentication (Phase 11) ─────────────────────────────────────────────────

# Switch between Entra ID SSO and the local argon2 credentials fallback.
# Values: 'entra' (default, production) | 'local' (dev / no Entra registration yet)
AUTH_MODE="local"

# Session signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# or: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-base64-string"

# ── Microsoft Entra ID (required when AUTH_MODE=entra) ────────────────────────

# Application (client) ID from the Entra app registration.
AUTH_MICROSOFT_ENTRA_ID_ID="00000000-0000-0000-0000-000000000000"

# Client secret value (not the secret ID) from the app registration.
AUTH_MICROSOFT_ENTRA_ID_SECRET="replace-with-entra-client-secret"

# Tenant issuer URL. Format: https://login.microsoftonline.com/<TENANT_ID>/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/your-tenant-id/v2.0"

# Tenant ID used for the allow-list check (must match the 'tid' claim in the token).
AUTH_ALLOWED_TENANT_ID="your-tenant-id"

# (Optional) Entra group / role object ID that the user must belong to.
# Leave empty to skip group membership enforcement.
AUTH_ALLOWED_GROUP_ID=""

# (Optional) Email domain allow-list, e.g. "mega.com.tr".
# Used only when AUTH_ALLOWED_GROUP_ID is empty. Leave empty to skip.
AUTH_ALLOWED_EMAIL_DOMAIN="mega.com.tr"

# ── Local admin fallback (required when AUTH_MODE=local) ─────────────────────

# The admin's email address (used as the actorId in audit logs).
ADMIN_EMAIL="admin@mega.com.tr"

# Argon2id hash of the admin password. Generate with:
#   node -e "require('argon2').hash('your-password').then(h => console.log(h))"
# Example output: $argon2id$v=19$m=65536,t=3,p=4$...
ADMIN_PASSWORD_HASH="replace-with-argon2id-hash"
