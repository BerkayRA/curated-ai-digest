{
  "name": "@digest/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 3100",
    "build": "next build --webpack",
    "start": "next start -p 3100",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test --config playwright.config.cjs",
    "test:e2e:update": "playwright test --config playwright.config.cjs --update-snapshots"
  },
  "dependencies": {
    "@digest/brand": "workspace:*",
    "@digest/curation": "workspace:*",
    "@digest/db": "workspace:*",
    "@digest/delivery": "workspace:*",
    "@digest/email": "workspace:*",
    "@digest/shared": "workspace:*",
    "argon2": "^0.41.1",
    "next": "^16.2.9",
    "next-auth": "5.0.0-beta.31",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "eslintConfig": {
    "root": true,
    "extends": "next/core-web-vitals",
    "ignorePatterns": [".next/", "node_modules/", "next-env.d.ts"]
  }
}
