# Anthropic API key — required for running the curation pipeline stages.
# Obtain from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Exa API key — required for the Exa neural search source in ingest.
EXA_API_KEY=

# Database URL — required for the Prisma-backed repository.
# Example: postgresql://user:pass@localhost:5432/mega_bulten
DATABASE_URL=
