generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum SourceType {
  rss
  radar
  exa
}

enum IssueStatus {
  draft
  in_review
  approved
  scheduled
  sent
  failed
  cancelled
}

enum ArticleStatus {
  candidate
  selected
  rejected
}

enum SendStatus {
  queued
  sent
  delivered
  bounced
  failed
}

enum EmailProviderKind {
  microsoft_graph
  acs_email
  resend
}

enum SubscriberStatus {
  active
  unsubscribed
  bounced
  // Double opt-in: membership awaiting email confirmation. NOT a dispatch
  // recipient (findActiveRecipients gates on status='active').
  pending
}

enum TopicStatus {
  active
  paused
}

// Lawful basis for a topic's recipients.
//   business — existing-relationship B2B: no prior opt-in required; admin/CSV
//              import only, NO public signup page.
//   public   — public signup page + double opt-in confirmation.
enum ConsentMode {
  business
  public
}

// Recorded lawful-basis trail for each SubscriberTopic membership (İYS-ready).
enum ConsentBasis {
  business_relationship
  double_opt_in
  import
  single_opt_in
}

// A/B subject-line test lifecycle on an Issue. `none` is the default — existing
// issues stay here and the send path is byte-identical to pre-Phase-4.
enum AbStatus {
  none
  testing // test fraction sent, awaiting the holdout window
  selecting // holdout expired, winner being chosen
  completed // remainder sent with the winning subject
}

// Why an email address was added to the global suppression list.
enum SuppressionReason {
  hard_bounce
  soft_bounce_threshold // accumulated soft bounces crossed the threshold
  complaint
  manual
}

// ---------------------------------------------------------------------------
// Topic — a configurable newsletter (its own sources, pool, issues, audience)
// ---------------------------------------------------------------------------

model Topic {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String?
  audience    String? // injected into rank/curate/QA prompts; null → default copy
  voice       String? // injected into copywrite/QA prompts; null → default copy
  status      TopicStatus @default(active)

  // Consent mode — `business` (no public signup; import only) is the safe
  // default; `public` opens a /s/<slug> signup page with double opt-in.
  consentMode ConsentMode @default(business) @map("consent_mode")

  // Per-topic schedule (nullable; null → fall back to global Settings)
  sendDayOfWeek    String?  @map("send_day_of_week")
  sendTime         String?  @map("send_time")
  timezone         String?
  pipelineLeadDays Int?     @map("pipeline_lead_days")
  autoSendEnabled  Boolean? @map("auto_send_enabled")

  // Per-topic delivery branding (nullable; null → fall back to global Settings)
  fromAddress   String? @map("from_address")
  replyTo       String? @map("reply_to")
  brandLogoUrl  String? @map("brand_logo_url")
  brandColorHex String? @map("brand_color_hex")
  // Display wordmark + footer descriptor for white-label email/archive; null →
  // fall back to the Mega/"Curated AI Digest" defaults.
  brandName       String? @map("brand_name")
  brandFooterText String? @map("brand_footer_text")

  // Content language for this topic's curation output + email/archive copy
  // ('tr' | 'en'). Default 'tr' → existing topics render identically to today.
  language String @default("tr")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sources         Source[]
  issues          Issue[]
  ingestRuns      IngestRun[]
  candidates      CandidateArticle[]
  subscriberTopics SubscriberTopic[]

  @@index([status])
  @@map("topics")
}

// ---------------------------------------------------------------------------
// Issue — one edition of a topic's newsletter
// ---------------------------------------------------------------------------

model Issue {
  id           String      @id @default(cuid())
  topicId      String      @map("topic_id")
  isoWeek      String      @map("iso_week") // e.g. "2026-W24"
  status       IssueStatus @default(draft)
  subject      String // TR marketing subject line
  preheader    String? // TR preview text
  bodyHtml     String?     @map("body_html") // rendered email HTML
  bodyJson     Json?       @map("body_json") // structured editable content
  scheduledAt  DateTime?   @map("scheduled_at")
  sentAt       DateTime?   @map("sent_at")
  approvedById String?     @map("approved_by_id") // FK reserved for future User model
  autoSent     Boolean     @default(false) @map("auto_sent")

  // A/B subject-line testing (Phase 4). `none` → no test (default; legacy issues).
  abStatus             AbStatus @default(none) @map("ab_status")
  abHoldoutMinutes     Int?     @map("ab_holdout_minutes") // null → scheduler default
  abWinnerVariantIndex Int?     @map("ab_winner_variant_index")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  topic    Topic            @relation(fields: [topicId], references: [id])
  items    IssueItem[]
  sends    Send[]
  variants SubjectVariant[]

  @@unique([topicId, isoWeek])
  @@index([status])
  @@index([topicId])
  @@map("issues")
}

// ---------------------------------------------------------------------------
// CandidateArticle — raw ingest candidates before editorial selection
// ---------------------------------------------------------------------------

model CandidateArticle {
  id              String        @id @default(cuid())
  topicId         String        @map("topic_id")
  sourceUrl       String        @map("source_url")
  sourceName      String        @map("source_name")
  title           String
  rawExcerpt      String?       @map("raw_excerpt")
  publishedAt     DateTime?     @map("published_at")
  contentHash     String        @map("content_hash") // SHA-256 for dedup (per-topic)
  importanceScore Float?        @map("importance_score")
  relevanceScore  Float?        @map("relevance_score")
  status          ArticleStatus @default(candidate)
  fetchedAt       DateTime      @default(now()) @map("fetched_at")
  ingestRunId     String?       @map("ingest_run_id")

  topic     Topic      @relation(fields: [topicId], references: [id])
  ingestRun IngestRun? @relation(fields: [ingestRunId], references: [id])

  @@unique([topicId, sourceUrl])
  @@unique([topicId, contentHash])
  @@index([status])
  @@index([ingestRunId])
  @@index([topicId])
  @@map("candidate_articles")
}

// ---------------------------------------------------------------------------
// IssueItem — curated items selected into a specific issue (max 3)
// ---------------------------------------------------------------------------

model IssueItem {
  id                 String  @id @default(cuid())
  issueId            String  @map("issue_id")
  candidateArticleId String? @map("candidate_article_id") // null for manually-added items
  order              Int // 0..2
  titleTr            String  @map("title_tr")
  summaryTr          String  @map("summary_tr")
  sourceUrl          String  @map("source_url")
  sourceName         String  @map("source_name")
  factCheckNotes     String? @map("fact_check_notes")
  qaFlags            Json?   @map("qa_flags")

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([issueId, order])
  @@index([issueId])
  @@map("issue_items")
}

// ---------------------------------------------------------------------------
// Subscriber — newsletter recipients
// ---------------------------------------------------------------------------

model Subscriber {
  id               String           @id @default(cuid())
  email            String           @unique
  displayName      String?          @map("display_name")
  company          String?
  status           SubscriberStatus @default(active)
  locale           String           @default("tr-TR")
  unsubscribeToken String           @unique @map("unsubscribe_token")
  source           String           @default("manual") // "manual" | "import"
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  subscriberTopics SubscriberTopic[]

  @@index([status])
  @@map("subscribers")
}

// ---------------------------------------------------------------------------
// SubscriberTopic — a subscriber's opt-in to one topic, with per-topic status
// and unsubscribe token. A subscriber (global email identity) joins any set of
// topics; delivery and per-topic opt-out are governed here.
// ---------------------------------------------------------------------------

model SubscriberTopic {
  id               String           @id @default(cuid())
  subscriberId     String           @map("subscriber_id")
  topicId          String           @map("topic_id")
  status           SubscriberStatus @default(active)
  unsubscribeToken String           @unique @map("unsubscribe_token")
  // Double opt-in confirmation token; set while status='pending', cleared
  // (NULL) on confirm. Partial-unique so many confirmed rows can share NULL.
  confirmToken     String?          @unique @map("confirm_token")
  // Recorded lawful basis for this membership (İYS-ready audit trail).
  consentBasis     ConsentBasis?    @map("consent_basis")
  consentAt        DateTime?        @map("consent_at")
  consentSource    String?          @map("consent_source") // e.g. public_signup, import, preferences_center
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  topic      Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  sends      Send[]

  @@unique([subscriberId, topicId])
  @@index([topicId, status])
  @@index([subscriberId])
  @@map("subscriber_topics")
}

// ---------------------------------------------------------------------------
// Settings — single-row application configuration (global defaults)
// ---------------------------------------------------------------------------

model Settings {
  id               String            @id @default(cuid())
  autoSendEnabled  Boolean           @default(false) @map("auto_send_enabled")
  sendDayOfWeek    String            @map("send_day_of_week") // e.g. "Thursday"
  sendTime         String            @map("send_time") // "HH:mm"
  timezone         String            @default("Europe/Istanbul")
  activeProvider   EmailProviderKind @default(acs_email) @map("active_provider")
  fromAddress      String            @map("from_address")
  replyTo          String?           @map("reply_to")
  pipelineLeadDays Int               @default(2) @map("pipeline_lead_days")
  /** DKIM selector for deliverability checks; null → provider default. */
  dkimSelector     String?           @map("dkim_selector")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@map("settings")
}

// ---------------------------------------------------------------------------
// Send — per-subscriber delivery record for each issue
// ---------------------------------------------------------------------------

model Send {
  id                String     @id @default(cuid())
  issueId           String     @map("issue_id")
  subscriberId      String     @map("subscriber_id")
  subscriberTopicId String?    @map("subscriber_topic_id")
  status            SendStatus @default(queued)
  providerMessageId String?    @map("provider_message_id")
  /** Opaque per-send token embedded in open-pixel + click links (engagement tracking). */
  trackToken        String     @unique @map("track_token")
  /** Which A/B subject variant this send used; null when no test ran. */
  variantIndex      Int?       @map("variant_index")
  error             String?
  sentAt            DateTime?  @map("sent_at")
  createdAt         DateTime   @default(now()) @map("created_at")

  issue           Issue            @relation(fields: [issueId], references: [id], onDelete: Cascade)
  subscriberTopic SubscriberTopic? @relation(fields: [subscriberTopicId], references: [id], onDelete: SetNull)
  events          EmailEvent[]

  @@index([issueId])
  @@index([subscriberId])
  @@map("sends")
}

// ---------------------------------------------------------------------------
// SubjectVariant — an A/B subject-line variant for an Issue. The test fraction
// of recipients is split across variants; the winner (highest open rate) is
// sent to the remainder. No variants → no test (the default path).
// ---------------------------------------------------------------------------

model SubjectVariant {
  id           String @id @default(cuid())
  issueId      String @map("issue_id")
  variantIndex Int    @map("variant_index") // 0, 1 (N-variant ready)
  subject      String
  testFraction Float  @default(0.5) @map("test_fraction") // share of the list in the test group
  sentCount    Int    @default(0) @map("sent_count")
  openCount    Int    @default(0) @map("open_count")

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([issueId, variantIndex])
  @@index([issueId])
  @@map("subject_variants")
}

// ---------------------------------------------------------------------------
// Suppression — GLOBAL do-not-send list keyed by email (distinct from per-topic
// unsubscribe). Fed by hard bounces / complaints (provider webhooks) and manual
// admin entries; dispatch filters these addresses across ALL topics.
// ---------------------------------------------------------------------------

model Suppression {
  id          String            @id @default(cuid())
  email       String            @unique
  reason      SuppressionReason
  source      String // "acs_webhook" | "resend_webhook" | "admin" | "backfill"
  bounceCount Int               @default(1) @map("bounce_count") // soft-bounce accumulator
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([email])
  @@map("suppressions")
}

// ---------------------------------------------------------------------------
// EmailEvent — engagement signal for a Send (open/click from tracking hooks;
// delivered/bounced/complaint from provider webhooks). Privacy-forward: no raw
// IP or user-agent — only a daily-salted ip hash and a coarse device class.
// ---------------------------------------------------------------------------

enum EmailEventType {
  open
  click
  delivered
  bounced
  complaint
}

model EmailEvent {
  id              String         @id @default(cuid())
  sendId          String         @map("send_id")
  type            EmailEventType
  url             String? // click destination (original story URL)
  urlIndex        Int?           @map("url_index") // which issue item was clicked
  ipHash          String?        @map("ip_hash") // daily-salted HMAC, never the raw IP
  uaClass         String?        @map("ua_class") // "mobile" | "desktop" | "bot" | "unknown"
  providerEventId String?        @unique @map("provider_event_id") // webhook dedup key
  occurredAt      DateTime       @map("occurred_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  send Send @relation(fields: [sendId], references: [id], onDelete: Cascade)

  @@index([sendId])
  @@index([type])
  @@map("email_events")
}

// ---------------------------------------------------------------------------
// IngestRun — tracks each article-fetch execution (per topic)
// ---------------------------------------------------------------------------

model IngestRun {
  id             String    @id @default(cuid())
  topicId        String?   @map("topic_id")
  startedAt      DateTime  @default(now()) @map("started_at")
  finishedAt     DateTime? @map("finished_at")
  source         String
  candidateCount Int       @default(0) @map("candidate_count")
  status         String
  error          String?

  topic    Topic?             @relation(fields: [topicId], references: [id])
  articles CandidateArticle[]

  @@index([status])
  @@index([topicId])
  @@map("ingest_runs")
}

// ---------------------------------------------------------------------------
// PipelineRun — cost-aware observability for AI pipeline stages
// ---------------------------------------------------------------------------

model PipelineRun {
  id         String    @id @default(cuid())
  issueId    String?   @map("issue_id")
  topicId    String?   @map("topic_id")
  stage      String // "rank" | "curate" | "copywrite" | "editor_qa" | "render"
  model      String
  tokensIn   Int       @default(0) @map("tokens_in")
  tokensOut  Int       @default(0) @map("tokens_out")
  costUsd    Float     @default(0) @map("cost_usd")
  status     String
  error      String?
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")

  @@index([issueId])
  @@index([stage])
  @@index([topicId])
  @@map("pipeline_runs")
}

// ---------------------------------------------------------------------------
// AuditLog — immutable record of all state-changing actions
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?  @map("actor_id")
  action    String // e.g. "issue.status_changed", "subscriber.created"
  entity    String // model name
  entityId  String   @map("entity_id")
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([actorId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Source — DB-backed registry of ingest sources (rss / radar / exa), per topic
// ---------------------------------------------------------------------------

model Source {
  id      String     @id @default(cuid())
  topicId String     @map("topic_id")
  type    SourceType
  label   String
  url     String? // rss/radar feed URL; null for exa
  enabled Boolean    @default(true)
  config  Json? // type-specific config blob (non-secret only)

  // Persistent health fields updated after each ingest run
  lastRunAt  DateTime? @map("last_run_at")
  lastStatus String?   @map("last_status") // "ok" | "error"
  lastCount  Int       @default(0) @map("last_count")
  lastError  String?   @map("last_error")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  topic Topic @relation(fields: [topicId], references: [id])

  // Postgres allows multiple NULLs in a unique index — fine for exa rows.
  @@unique([topicId, type, url])
  @@index([enabled])
  @@index([topicId])
  @@map("sources")
}
