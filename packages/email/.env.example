# =============================================================================
# @digest/email — provider environment variables
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Active provider selection (used by apps/worker Settings.activeProvider)
# Values: acs_email | microsoft_graph | resend
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=acs_email

# =============================================================================
# ACS Email (default provider)
# Docs: https://learn.microsoft.com/azure/communication-services/concepts/email/
# =============================================================================

# Option A — connection-string auth (simplest; rotatable via Azure portal)
ACS_CONNECTION_STRING=endpoint=https://YOUR_RESOURCE.communication.azure.com/;accesskey=YOUR_KEY

# Option B — managed-identity / workload-identity auth (preferred for production)
# Leave ACS_CONNECTION_STRING unset and set only ACS_ENDPOINT.
# DefaultAzureCredential picks up Managed Identity, Workload Identity,
# Azure CLI, Visual Studio Code credential, etc. automatically.
ACS_ENDPOINT=https://YOUR_RESOURCE.communication.azure.com/

# Verified sender address configured in your ACS resource (required for both modes)
ACS_SENDER_ADDRESS=digest@YOUR_VERIFIED_DOMAIN.com

# =============================================================================
# Microsoft Graph (via app registration + client credentials)
# Docs: https://learn.microsoft.com/graph/api/user-sendmail
#
# THROTTLE CAVEAT: Graph sendMail is subject to Exchange Online throttling
# (~4 req/s burst per tenant). Use ACS or Resend for bulk sends.
# =============================================================================

GRAPH_TENANT_ID=your-azure-ad-tenant-id
GRAPH_CLIENT_ID=your-app-registration-client-id
GRAPH_CLIENT_SECRET=your-app-registration-client-secret

# UPN or object ID of the shared mailbox / licensed user with Mail.Send permission
GRAPH_SENDER_ID=digest@YOUR_DOMAIN.com

# =============================================================================
# Resend
# Docs: https://resend.com/docs/send-with-nodejs
# =============================================================================

RESEND_API_KEY=re_YOUR_API_KEY_HERE
