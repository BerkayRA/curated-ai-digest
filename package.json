{
  "name": "mega-bulten",
  "version": "0.1.0",
  "private": true,
  "description": "Mega Bülten — weekly AI-news digest newsletter system. Claude-powered curation agents + branded email + approval dashboard for Mega Bilgisayar Tic. Ltd. Şti.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:up": "docker compose up -d db adminer",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @mega-bulten/db migrate",
    "db:seed": "pnpm --filter @mega-bulten/db seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@prisma/client", "prisma", "@prisma/engines", "argon2", "sharp"]
  }
}
